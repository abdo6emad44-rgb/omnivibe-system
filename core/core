from django.db import models

# جدول المنتجات (المخزن)
class Product(models.Model):
    name = models.CharField(max_length=200, verbose_name="اسم المنتج")
    price = models.DecimalField(max_digits=10, decimal_places=2, verbose_name="السعر")
    stock = models.IntegerField(verbose_name="الكمية المتاحة")

    def __str__(self):
        return self.name

# جدول المبيعات (الفواتير)
class Sale(models.Model):
    product = models.ForeignKey(Product, on_delete=models.CASCADE, verbose_name="المنتج")
    quantity = models.PositiveIntegerField(verbose_name="الكمية المباعة")
    date = models.DateTimeField(auto_now_add=True, verbose_name="تاريخ البيع")